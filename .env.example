# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/madnesslab"

# Redis (for caching and rate limiting)
REDIS_URL="redis://localhost:6379"

# AI Configuration
# Supported providers: "openai" | "anthropic" | "none"
AI_PROVIDER="anthropic"
AI_API_KEY="your-api-key-here"
AI_MODEL="claude-haiku-4-5"

# Set to "true" to run the app entirely with mock/seed data (no real DB required)
USE_MOCK_DATA="true"

# App URL (used for metadata)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
